{
  "name": "javascript-in-14-minutes-malayalam",
  "version": "1.0.0",
  "description": "The Malayalam translation of JavaScript in 14 Minutes.",
  "keywords": [
    "sass",
    "bulma",
    "css",
    "tutorial",
    "javascript"
  ],
  "homepage": "https://github.com/DigitalMalayaliStudio/javascript-in-14-minutes-malayalam#readme",
  "bugs": {
    "url": "https://github.com/DigitalMalayaliStudio/javascript-in-14-minutes-malayalam/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DigitalMalayaliStudio/javascript-in-14-minutes-malayalam.git"
  },
  "license": "MIT",
  "author": "Jeremy Thomas",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "css-deploy": "npm run css-build && npm run css-autoprefix && npm run css-minify",
    "css-build": "sass --load-path=node_modules _sass/main.scss css/main.css",
    "css-autoprefix": "postcss --no-map --use autoprefixer --output css/main.css css/main.css",
    "css-minify": "postcss --no-map --config postcss.config.js --output css/main.min.css css/main.css",
    "start": "npm run css-build -- --watch"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-malayalam": "^5.2.8",
    "autoprefixer": "^10.4.27",
    "bulma": "^1.0.4",
    "cssnano": "^7.1.3",
    "sass": "^1.98.0"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1"
  }
}
